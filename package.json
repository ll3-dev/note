{
  "name": "note",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run build:engine && bun scripts/dev.ts",
    "dev:electrobun": "electrobun dev",
    "dev:vite": "vite",
    "build": "bun run build:engine && bun run build:mainview && electrobun build",
    "build:dev": "bun run build:engine && bun run build:mainview && electrobun build",
    "build:engine": "cargo build -p note-engine",
    "build:mainview": "vite build",
    "check": "cargo test && cargo check && bun run typecheck && bun run test && bun run build",
    "test": "bun test src",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-router": "^1.168.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "^1.16.0",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^8.0.10"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
